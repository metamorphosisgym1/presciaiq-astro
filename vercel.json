{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "presciaiq.com.au" }],
      "destination": "https://www.presciaiq.com.au/:path*",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms-of-service",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/careers",
      "destination": "/about",
      "permanent": true
    }
  ]
}
