---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PresciaIQ — Intelligence That Moves First | Australia's AI Company",
  description = "PresciaIQ builds AI-powered intelligence tools that turn raw data into competitive advantage.",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <Navbar client:load />
    <main><slot /></main>
    <Footer client:load />
  </body>
</html>
