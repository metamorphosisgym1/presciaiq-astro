---
import Analytics from "@vercel/analytics/astro";
import '../styles/global.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PresciaIQ — Intelligence That Moves First | Australia's AI Company",
  description = "PresciaIQ builds AI-powered intelligence tools that turn raw data into competitive advantage.",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta name="msvalidate.01" content="D131AC8A623B85D9575E1D1CA1EC6377" />
    <meta name="google-site-verification" content="YkvGLb0AsKnv6O2YYsrsXeVaAMxlK3v1xhrrqkcarak" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
      
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-VGKZVCWFXQ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag( ){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-VGKZVCWFXQ');
</script>


    <!-- SEO: Primary Meta Tags -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="language" content="en-AU" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="en-AU" href={Astro.url.href} />
    <link rel="alternate" hreflang="x-default" href={Astro.url.href} />

    <!-- SEO: Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="PresciaIQ builds AI-powered intelligence tools for Australian SMBs. Predict construction risk, forecast ad spend, and eliminate operational guesswork." />
    <meta property="og:image" content="https://www.presciaiq.com.au/og-image.jpg" />
    <meta property="og:site_name" content="PresciaIQ" />
    <meta property="og:locale" content="en_AU" />

    <!-- SEO: Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="PresciaIQ builds AI-powered intelligence tools for Australian SMBs. Predict construction risk, forecast ad spend, and eliminate operational guesswork." />
    <meta name="twitter:image" content="https://www.presciaiq.com.au/og-image.jpg" />

    <!-- AEO: JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://www.presciaiq.com.au/#organization",
          "name": "PresciaIQ",
          "legalName": "PredictIQ Holdings Pty Ltd",
          "url": "https://www.presciaiq.com.au",
          "logo": { "@type": "ImageObject", "url": "https://www.presciaiq.com.au/logo.png" },
          "description": "Australia's predictive AI intelligence company. We build AI forecasting tools for construction, marketing, operations, and trades.",
          "foundingDate": "2024",
          "foundingLocation": "Sydney, NSW, Australia",
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "sales@presciaiq.com.au",
            "telephone": "+61400457006",
            "contactType": "sales",
            "areaServed": "AU",
            "availableLanguage": "en"
          },
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Sydney",
            "addressRegion": "NSW",
            "addressCountry": "AU"
          },
          "sameAs": ["https://www.linkedin.com/company/presciaiq"]
        },
        {
          "@type": "WebSite",
          "@id": "https://www.presciaiq.com.au/#website",
          "url": "https://www.presciaiq.com.au",
          "name": "PresciaIQ",
          "description": "Australia's AI Intelligence & Development Company",
          "publisher": { "@id": "https://www.presciaiq.com.au/#organization" },
          "inLanguage": "en-AU"
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "What is PresciaIQ?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "PresciaIQ is Australia's predictive AI intelligence company, based in Sydney. We build AI forecasting tools across four verticals — construction risk (BuildPredictIQ ), marketing spend (AdsIQ), operations (OpsIQ), and trades (TradesmanIQ) — to help Australian SMBs act on intelligence before problems occur."
              }
            },
            {
              "@type": "Question",
              "name": "What is the Reaction Tax?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The Reaction Tax is the hidden cost every business pays when it learns something after it has already happened — the ad spend burned on a failing campaign, the build that slips because nobody saw the supplier delay, or the warehouse that ran dry when demand spiked. PresciaIQ was built to eliminate the Reaction Tax by giving Australian operators predictive intelligence before decisions need to be made."
              }
            },
            {
              "@type": "Question",
              "name": "What products does PresciaIQ offer?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "PresciaIQ offers four AI intelligence products: BuildPredictIQ (construction risk and budget forecasting), AdsIQ (campaign timing and spend prediction for marketing teams), OpsIQ (operational bottleneck prediction for logistics-heavy businesses), and TradesmanIQ (job profitability and scheduling intelligence for trades, launching 2026)."
              }
            },
            {
              "@type": "Question",
              "name": "Is PresciaIQ built for Australian businesses?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. PresciaIQ is built in Sydney specifically for Australian SMB and mid-market operating conditions. Every product is designed around Australian regulations, market dynamics, and the specific decisions Australian operators make — not retrofitted from US-built enterprise tooling."
              }
            },
      {
        "@type": "Question",
        "name": "How does BuildPredictIQ calculate geotechnical risk?",
        "acceptedAnswer": { "@type": "Answer", "text": "BuildPredictIQ analyses historical site data, local geological surveys, and weather patterns using predictive AI to forecast potential geotechnical risks before excavation begins, giving builders early warning to adjust scope and budget." }
      },
      {
        "@type": "Question",
        "name": "What data does AdsIQ use to predict ROAS?",
        "acceptedAnswer": { "@type": "Answer", "text": "AdsIQ aggregates historical campaign performance, market seasonality, competitor spend velocity, and platform algorithm signals to forecast Return on Ad Spend, helping marketing teams allocate budget before campaigns launch." }
      },
      {
        "@type": "Question",
        "name": "Is PresciaIQ suitable for small businesses in Australia?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. PresciaIQ is purpose-built for Australian SMBs and mid-market operators. Every product is priced and designed for businesses that need enterprise-grade intelligence without enterprise-grade cost or complexity." }
      },
      {
        "@type": "Question",
        "name": "What is predictive analytics?",
        "acceptedAnswer": { "@type": "Answer", "text": "Predictive analytics uses historical data, statistical algorithms, and machine learning to forecast the likelihood of future outcomes. For businesses, this means anticipating risk, demand, and cost before they materialise rather than reacting after the fact." }
      },

      {
        "@type": "Question",
        "name": "Where is PresciaIQ based?",
        "acceptedAnswer": { "@type": "Answer", "text": "PresciaIQ is headquartered in Sydney, Australia at 100 Harris St, Pyrmont NSW 2009. The company is Australian-built and designed specifically for Australian business conditions, regulations, and markets." }
      }
          ]
        }
      ]
    })} />

  
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "BuildPredictIQ",
      "operatingSystem": "Web",
      "applicationCategory": "BusinessApplication",
      "description": "AI-powered construction risk and budget intelligence platform for Australian builders and developers.",
      "offers": { "@type": "Offer", "price": "4999", "priceCurrency": "AUD" }
    },
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "AdsIQ",
      "operatingSystem": "Web",
      "applicationCategory": "BusinessApplication",
      "description": "Campaign timing and ROAS forecasting platform for Australian marketing teams and media buyers.",
      "offers": { "@type": "Offer", "price": "4999", "priceCurrency": "AUD" }
    }
  ]
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "PresciaIQ",
    "image": "https://presciaiq.com.au/og-image.jpg",
    "url": "https://presciaiq.com.au",
    "telephone": "+61-2-0000-0000",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "100 Harris St",
      "addressLocality": "Pyrmont",
      "addressRegion": "NSW",
      "postalCode": "2009",
      "addressCountry": "AU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -33.8688,
      "longitude": 151.1957
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "17:00"
    }
  }
  </script>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
  <body>
    <Navbar client:load />
    <main><slot /></main>
    <Footer client:load />
    <Analytics />
  </body>
</html>
