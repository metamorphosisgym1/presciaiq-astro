---
import Layout from '../layouts/Layout.astro';
import WhySection from '../components/sections/WhySection';
import LeadCaptureSection from '../components/sections/LeadCaptureSection';
---

<Layout title="About PresciaIQ | Australian AI Intelligence Company" description="Learn about PresciaIQ — the Australian-built predictive AI company helping SMBs eliminate operational guesswork. Meet the founders and our mission.">
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alex Cutajar",
      "jobTitle": "Co-Founder",
      "worksFor": { "@type": "Organization", "name": "PresciaIQ" },
      "description": "Alex Cutajar is a co-founder of PresciaIQ with a background in SMB and FMCG operations and applied AI.",
      "sameAs": ["https://www.linkedin.com/company/presciaiq-holdings"]
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Macauley Burke",
      "jobTitle": "Co-Founder",
      "worksFor": { "@type": "Organization", "name": "PresciaIQ" },
      "description": "Macauley Burke is a co-founder of PresciaIQ with a background in B2B sales and enterprise client development.",
      "sameAs": ["https://www.linkedin.com/company/presciaiq-holdings"]
    }
  ]
  </script>
  <h1 class="sr-only">About PresciaIQ — Australian AI Intelligence Company</h1>
  <div class="pt-12">
    <WhySection client:load />
    <LeadCaptureSection client:load />
    <div class="mt-4 text-sm text-muted-foreground font-sans">
      <strong class="text-foreground">Sydney Office</strong>  

      100 Harris St, Pyrmont NSW 2009, Australia
    </div>
  </div>
</Layout>
