---
import Layout from '../../layouts/Layout.astro';
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://presciaiq.com.au" },
    { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://presciaiq.com.au/insights" }
  ]
}
</script>

<Layout title="Insights | Predictive Analytics &amp; AI Intelligence | PresciaIQ" description="Expert insights on predictive analytics, AI for construction, marketing spend forecasting, and operational intelligence for Australian businesses.">
  <div class="pt-32 pb-24 min-h-screen">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-16 text-center">
        <p class="text-primary font-bold uppercase tracking-widest text-xs mb-4 font-sans">Intelligence Hub</p>
        <h1 class="font-display text-4xl md:text-6xl font-bold text-foreground mb-6">Insights</h1>
        <p class="text-lg text-muted-foreground font-sans max-w-2xl mx-auto">Practical intelligence on AI, predictive analytics, and the decisions that determine whether Australian businesses grow or stall.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/insights/the-reaction-tax" class="glass-card-hover p-6 flex flex-col group" style="text-decoration:none;">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-bold text-primary uppercase tracking-widest font-sans">Strategy</span>
            <span class="text-xs text-muted-foreground font-sans">4 min read</span>
          </div>
          <h2 class="font-display text-lg font-bold text-foreground mb-3 group-hover:text-primary transition-colors leading-snug">The Reaction Tax</h2>
          <p class="text-sm text-muted-foreground font-sans mb-4 flex-1 leading-relaxed">Every business in Australia pays a tax that never appears on a P&L. It is the price a business pays every time it learns something after it has already happened.</p>
          <div class="flex items-center text-sm font-bold text-foreground group-hover:text-primary transition-colors mt-auto font-sans">Read Article &rarr;</div>
        </a>
        <a href="/insights/ai-construction-risk-assessment-australia" class="glass-card-hover p-6 flex flex-col group" style="text-decoration:none;">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-bold text-primary uppercase tracking-widest font-sans">Construction</span>
            <span class="text-xs text-muted-foreground font-sans">6 min read</span>
          </div>
          <h2 class="font-display text-lg font-bold text-foreground mb-3 group-hover:text-primary transition-colors leading-snug">AI Construction Risk Assessment in Australia</h2>
          <p class="text-sm text-muted-foreground font-sans mb-4 flex-1 leading-relaxed">How AI-powered construction risk assessment is helping Australian builders predict budget blowouts, delays, and compliance failures before they happen.</p>
          <div class="flex items-center text-sm font-bold text-foreground group-hover:text-primary transition-colors mt-auto font-sans">Read Article &rarr;</div>
        </a>
        <a href="/insights/roas-prediction-tool-australian-marketing" class="glass-card-hover p-6 flex flex-col group" style="text-decoration:none;">
