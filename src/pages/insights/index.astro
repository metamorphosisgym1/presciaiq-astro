---

import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/SectionWrapper';
import { ArrowRight } from 'lucide-react';

const articles = [
  {
    title: "The Reaction Tax",
    excerpt: "Every business in Australia pays a tax that never appears on a P&L. It is the price a business pays every time it learns something after it has already happened.",
    date: "April 2026",
    readTime: "4 min read",
    url: "/insights/the-reaction-tax",
    category: "Strategy"
  }
];
---

<Layout title="Insights | Predictive Analytics & AI Intelligence | PresciaIQ" description="Expert insights on predictive analytics, AI for construction, marketing spend forecasting, and operational intelligence for Australian businesses.">
  <div class="pt-12">
    <SectionWrapper id="insights-header" className="py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-display text-4xl md:text-6xl font-bold text-foreground mb-6">
          Intelligence <span class="text-primary neon-glow">Insights</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto font-sans">
          Perspectives on predictive AI, operational efficiency, and the future of Australian SMBs.
        </p>
      </div>
    </SectionWrapper>

    <SectionWrapper id="insights-grid" className="pb-24 md:pb-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.map((article) => (
            <a href={article.url} class="group block h-full">
              <div class="glass-card-hover p-8 h-full flex flex-col relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                <div class="relative z-10 flex-1 flex flex-col">
                  <div class="flex justify-between items-center mb-4">
                    <span class="text-xs font-bold text-primary uppercase tracking-wider">{article.category}</span>
                    <span class="text-xs text-muted-foreground">{article.readTime}</span>
                  </div>
                  <h3 class="font-display text-2xl font-bold text-foreground mb-4 group-hover:text-primary transition-colors">
                    {article.title}
                  </h3>
                  <p class="text-muted-foreground font-sans mb-6 flex-1">
                    {article.excerpt}
                  </p>
                  <div class="flex items-center text-sm font-bold text-foreground group-hover:text-primary transition-colors mt-auto">
                    Read Article <ArrowRight className="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </SectionWrapper>
  </div>
</Layout>
