---
import Layout from '../layouts/Layout.astro';
import AppBuildingSection from '../components/sections/AppBuildingSection';
import ProofOfWorkSection from '../components/sections/ProofOfWorkSection';
import PricingSection from '../components/sections/PricingSection';
import LeadCaptureSection from '../components/sections/LeadCaptureSection';
---
<Layout title="Web & App Development Sydney | PresciaIQ" description="High-performance web and app development in Sydney. We build AI-ready digital platforms using React, Next.js, and modern architecture for Australian businesses.">
  <h1 class="font-display text-4xl md:text-5xl font-bold text-foreground mb-8">Web & App Development Sydney — PresciaIQ</h1>
  <div class="pt-12">
    <AppBuildingSection client:load />
    <ProofOfWorkSection client:load />
    <PricingSection client:load />
    <LeadCaptureSection client:load />
  </div>
</Layout>
